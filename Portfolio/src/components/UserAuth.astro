    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .user-auth__avatar-btn:hover {
    background: var(--color-border-hover, #f3f4f6);
  }

  .user-auth__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-primary, #3b82f6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .user-auth__name {
    font-size: 0.85rem;
    color: var(--color-text, #1f2937);
    font-weight: 500;
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .user-auth__arrow {
    transition: transform 0.2s;
    color: var(--color-text-muted, #9ca3af);
  }

  .user-auth__arrow {
    transition: transform 0.2s;
  }

  .user-auth__dropdown--open ~ .user-auth__arrow,
