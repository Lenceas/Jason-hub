<div id="user-auth" class="user-auth">
  <div id="user-auth-loading" class="user-auth__loading"></div>
  <a id="user-auth-login" href="https://api-auth.lujiesheng.cn/login?redirect=https://lujiesheng.cn" class="user-auth__login" style="display:none">
    登录
  </a>
  <div id="user-auth-panel" class="user-auth__panel" style="display:none">
    <button class="user-auth__avatar-btn" id="user-auth-toggle" aria-label="用户菜单">
      <span class="user-auth__avatar" id="user-auth-avatar"></span>
      <span class="user-auth__name" id="user-auth-name"></span>
      <svg class="user-auth__arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M3 5L6 8L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="user-auth__dropdown" id="user-auth-dropdown">
      <div class="user-auth__dropdown-info">
        <span class="user-auth__dropdown-role" id="user-auth-role"></span>
      </div>
      <hr class="user-auth__divider" />
      <a href="https://api-auth.lujiesheng.cn/login?redirect=https://lujiesheng.cn" class="user-auth__dropdown-item" id="user-auth-logout">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M5 13H2.5C2.102 13 1.904 13 1.755 12.922C1.622 12.853 1.517 12.748 1.448 12.615C1.37 12.466 1.37 12.268 1.37 11.87V2.13C1.37 1.732 1.37 1.534 1.448 1.385C1.517 1.252 1.622 1.147 1.755 1.078C1.904 1 2.102 1 2.5 1H5M9.5 10L13 7M13 7L9.5 4M13 7H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        退出登录
      </a>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const AUTH_API = 'https://api-auth.lujiesheng.cn';
  const LOGIN_URL = AUTH_API + '/login?redirect=' + encodeURIComponent(window.location.origin);

  var loadingEl = document.getElementById('user-auth-loading');
  var loginEl = document.getElementById('user-auth-login');
  var panelEl = document.getElementById('user-auth-panel');
  var nameEl = document.getElementById('user-auth-name');
  var avatarEl = document.getElementById('user-auth-avatar');
  var roleEl = document.getElementById('user-auth-role');
  var toggleBtn = document.getElementById('user-auth-toggle');
  var dropdownEl = document.getElementById('user-auth-dropdown');
  var logoutEl = document.getElementById('user-auth-logout');

  // 更新登录链接（保留当前路径）
  loginEl.href = LOGIN_URL;
  logoutEl.href = LOGIN_URL;

  // 检查登录状态
  fetch(AUTH_API + '/api/v1/auth/me', { credentials: 'include' })
    .then(function(res) {
      if (res.ok) return res.json();
      throw new Error('not logged in');
    })
    .then(function(data) {
      loadingEl.style.display = 'none';
      panelEl.style.display = '';

      // 显示用户名（取首字符作为头像占位）
      var displayName = data.username || '?';
      nameEl.textContent = displayName;
      avatarEl.textContent = displayName.charAt(0).toUpperCase();
      roleEl.textContent = data.role === 'admin' ? '管理员' : '用户';

      // 点击头像切换下拉菜单
      toggleBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdownEl.classList.toggle('user-auth__dropdown--open');
      });

      // 点击外部关闭下拉
      document.addEventListener('click', function() {
        dropdownEl.classList.remove('user-auth__dropdown--open');
      });
    })
    .catch(function() {
      // 未登录 — 显示登录按钮
      loadingEl.style.display = 'none';
      loginEl.style.display = '';
    });
})();
</script>

<style>
