---
export interface Props {
  id: string;
  title: string;
  tagline: string;
  description: string;
  status: 'active' | 'planning' | 'archived';
  url: string;
  thumbnail: string;
  tags: string[];
  year: number;
  featured?: boolean;
}

const { id, title, tagline, description, status, url, thumbnail, tags, year, featured } = Astro.props;

const statusLabel: Record<string, { text: string; color: string }> = {
  active: { text: '进行中', color: '#22C55E' },
  planning: { text: '规划中', color: '#F59E0B' },
  archived: { text: '已归档', color: '#94A3B8' },
};
---

<article class="card glass" data-aos>
  <a href={url} target="_blank" rel="noopener noreferrer" class="card__link">
    <!-- 精选标识 -->
    {featured && <span class="card__featured">精选</span>}

    <!-- 缩略图 -->
    <div class="card__thumb">
      <img src={thumbnail} alt={title} loading="lazy" />
      <span class="card__status" style={{ backgroundColor: statusLabel[status].color }}>
        {statusLabel[status].text}
      </span>
    </div>

    <!-- 内容 -->
    <div class="card__body">
      <div class="card__header">
        <h3 class="card__title">{title}</h3>
        <span class="card__year">{year}</span>
      </div>
      <p class="card__tagline">{tagline}</p>
      <p class="card__desc">{description}</p>

      <!-- 标签 -->
      <div class="card__tags">
        {tags.map((tag) => (
          <span class="card__tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    position: relative;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(59, 130, 246, 0.1), var(--shadow-lg);
  }

  @media (hover: none) {
    .card:hover {
      transform: none;
      box-shadow: none;
    }

    .card:active {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }
  }

  .card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ---- 精选标识 ---- */
  .card__featured {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    color: #F59E0B;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(245, 158, 11, 0.3);
    letter-spacing: 0.03em;
  }

  .card__thumb {
    position: relative;
    aspect-ratio: 5 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card__thumb img {
    transform: scale(1.05);
  }

  .card__status {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.01em;
  }

  .card__body {
    padding: 1rem;
  }

  .card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }

  .card__title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .card__year {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 450;
  }

  .card__tagline {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .card__desc {
    font-size: 0.825rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.85rem;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card__tag {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-primary);
    background: var(--color-primary-lighter);
    border-radius: 999px;
  }

  /* 平板 ≥640px */
  @media (min-width: 640px) {
    .card__body {
      padding: 1.25rem;
    }

    .card__title {
      font-size: 1.125rem;
    }

    .card__desc {
      font-size: 0.875rem;
    }

    .card__tag {
      font-size: 0.75rem;
    }

    .card__status {
      top: 12px;
      right: 12px;
      padding: 3px 10px;
      font-size: 0.75rem;
    }

    .card__featured {
      top: 12px;
      left: 12px;
      padding: 3px 10px;
      font-size: 0.75rem;
    }
  }
</style>
