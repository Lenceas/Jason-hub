---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Values from '../components/Values.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import Footer from '../components/Footer.astro';

import projects from '../data/projects.json';
import type { Props as CardProps } from '../components/ProjectCard.astro';

const statusOrder: Record<string, number> = { completed: 0, active: 1, planning: 2, archived: 3 };
const sortedProjects = [...projects].sort((a, b) => {
  const fa = a.featured ? 0 : 1;
  const fb = b.featured ? 0 : 1;
  if (fa !== fb) return fa - fb;
  return (statusOrder[a.status] ?? 2) - (statusOrder[b.status] ?? 2);
});

const levelOrder = { expert: 0, advanced: 1, intermediate: 2, beginner: 3 };

const skills = [
  { name: "Vibe Coding", level: "expert" as const },
  { name: "C# .NET", level: "expert" as const },
  { name: "Vue", level: "advanced" as const },
  { name: "TypeScript", level: "advanced" as const },
  { name: "小程序", level: "advanced" as const },  
  { name: "Docker", level: "intermediate" as const },
  { name: "MySQL", level: "intermediate" as const },
  { name: "Redis", level: "intermediate" as const },
  { name: "MQTT", level: "intermediate" as const },
].sort((a, b) => levelOrder[a.level] - levelOrder[b.level]);
---

<BaseLayout
  title="Jason · 个人主页 · AI 全栈开发者"
  description="卢杰晟（Jason）的个人主页。AI 全栈开发者，专注 Vibe Coding / C# .NET / Vue / TypeScript，热爱开源与创造。项目展示、技能标签、个人介绍一站浏览。"
>

  <Header />
  <main>
    <Hero
      name="Jason"
      tagline="用代码构建有趣的东西"
      slogan="✧ AI 全栈开发者 · 持续学习中 ✧"
      bio={[
        "热爱编程，持续学习，乐于分享。",
        "专注于 AI 全栈开发 与个人项目探索。",
      ]}
      socialLinks={[
        { label: "GitHub", url: "https://github.com/Lenceas" },
        { label: "Gitee", url: "https://gitee.com/lujiesheng" },
        { label: "博客园", url: "https://www.cnblogs.com/lujiesheng" },
        { label: "Email", url: "mailto:2923280915@qq.com" },
      ]}
    />

    <Values />

    <Skills {skills} />

    <ProjectGrid projects={sortedProjects as CardProps[]} />
  </main>
  <Footer />

</BaseLayout>
